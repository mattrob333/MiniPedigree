# ── App ────────────────────────────────────────────────────────────────
VITE_APP_NAME="Pedigree Discover Lite"

# ── Server / OpenAI ────────────────────────────────────────────────────
# When OPENAI_API_KEY is set, the server uses real GPT structured outputs for
# transcript parsing and agent-manifest generation. When unset, the server
# (and client) fall back to deterministic demo logic so the app still works.
OPENAI_API_KEY=""
# gpt-5.5 (reasoning model, served via the Responses API). Any Responses-API model works.
OPENAI_MODEL="gpt-5.5"
# Reasoning effort for gpt-5.x / o-series: low | medium | high | xhigh
OPENAI_REASONING_EFFORT="medium"
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-transcribe"

# Speech-to-text provider: openai | deepgram | none
TRANSCRIPTION_PROVIDER="openai"
DEEPGRAM_API_KEY=""

API_PORT="8787"
MAX_AUDIO_UPLOAD_MB="25"
MAX_CSV_ROWS="500"

# ── Supabase (optional) ────────────────────────────────────────────────
# When these are set, workspaces/people persist to Supabase Postgres.
# When unset, the app persists to browser localStorage.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
