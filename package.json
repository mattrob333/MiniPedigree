{
  "name": "pedigree-discover-lite",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pedigree Discover Lite — CSV-to-Agent Prompt MVP. Upload a people CSV, map responsibilities, and compile per-person AI agent prompts anchored to a human owner.",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"vite\" \"npm:server\"",
    "dev:client": "vite",
    "server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node --import tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@xyflow/react": "^12.3.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "formidable": "^3.5.4",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.3",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/formidable": "^3.5.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.4",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^3.2.29",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
